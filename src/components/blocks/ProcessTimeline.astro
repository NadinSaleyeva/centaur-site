---
import { t } from '../../i18n/config';

const steps = [
  { num: '01', title: t('process.1.title'), desc: t('process.1.desc'), time: t('process.1.time') },
  { num: '02', title: t('process.2.title'), desc: t('process.2.desc'), time: t('process.2.time') },
  { num: '03', title: t('process.3.title'), desc: t('process.3.desc'), time: t('process.3.time') },
  { num: '04', title: t('process.4.title'), desc: t('process.4.desc'), time: t('process.4.time') },
];
---

<section id="process" class="py-24 md:py-32 bg-gradient-to-br from-hero-from via-hero-via to-hero-to">
  <div class="max-w-[1120px] mx-auto px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <p class="text-accent font-medium text-sm uppercase tracking-[0.2em] mb-4">{t('process.eyebrow')}</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white leading-tight">{t('process.title')}</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {steps.map((step, i) => (
        <div class="relative p-6 rounded-xl border border-white/10 bg-white/5">
          <div class="flex items-center gap-3 mb-4">
            <span class="w-9 h-9 rounded-full bg-accent flex items-center justify-center text-white text-xs font-bold">{step.num}</span>
            <span class="text-xs text-accent font-medium uppercase tracking-wider">{step.time}</span>
          </div>
          <h3 class="text-base font-bold text-white mb-2">{step.title}</h3>
          <p class="text-sm text-white/60 leading-relaxed">{step.desc}</p>
          {i < steps.length - 1 && (
            <div class="hidden lg:block absolute top-1/2 -right-3 w-6 text-white/20">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9,6 15,12 9,18"/></svg>
            </div>
          )}
        </div>
      ))}
    </div>

    <div class="text-center mt-10">
      <a href="/ru/kak-my-rabotaem/" class="inline-flex items-center gap-2 text-accent text-sm font-medium hover:gap-3 transition-all">
        {t('process.link')}
        <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="8" x2="13" y2="8"/><polyline points="9,4 13,8 9,12"/></svg>
      </a>
    </div>
  </div>
</section>
