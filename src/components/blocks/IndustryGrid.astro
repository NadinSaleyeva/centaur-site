---
import { industries } from '../../data/industries';
import { t } from '../../i18n/config';
---

<section id="industries" class="pt-10 pb-24 md:pb-32 bg-white">
  <div class="max-w-[1656px] mx-auto px-6 lg:px-8">
    <div class="text-center mb-16 md:mb-20">
      <h2 class="text-4xl md:text-5xl lg:text-[70px] font-extrabold leading-[1.1] tracking-tight mb-6 text-[#1a1a1a]">{t('industries.title')}</h2>
      <p class="max-w-2xl mx-auto text-[#1a1a1a]/40 text-[16px] leading-relaxed font-medium">{t('industries.description')}</p>
    </div>
  </div>

  <!-- Horizontal scroll with arrows -->
  <div class="relative max-w-[1656px] mx-auto px-6 lg:px-8">
    <!-- Left arrow -->
    <button class="industry-prev absolute left-2 lg:left-0 top-1/2 -translate-y-1/2 z-10 w-10 h-10 rounded-full border border-black/[0.1] bg-white/80 backdrop-blur-sm flex items-center justify-center hover:bg-[#f0f0f0] transition-colors">
      <svg class="w-4 h-4 text-[#1a1a1a]/60" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="10,4 6,8 10,12"/></svg>
    </button>

    <!-- Right arrow -->
    <button class="industry-next absolute right-2 lg:right-0 top-1/2 -translate-y-1/2 z-10 w-10 h-10 rounded-full border border-black/[0.1] bg-white/80 backdrop-blur-sm flex items-center justify-center hover:bg-[#f0f0f0] transition-colors">
      <svg class="w-4 h-4 text-[#1a1a1a]/60" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6,4 10,8 6,12"/></svg>
    </button>

    <div class="overflow-x-auto scrollbar-hide industry-scroll mx-8">
      <div class="flex gap-5 pb-4">
        {industries.map((ind) => (
          <a href={`/ru/otrasli/${ind.slug}/`} class="group flex-shrink-0 w-[280px] p-8 rounded-2xl border border-black/[0.06] bg-[#f8f8f8] hover:shadow-[0_8px_30px_rgba(0,0,0,0.08)] hover:border-black/[0.1] transition-all duration-300 text-center">
            <div class="w-14 h-14 rounded-2xl bg-white border border-black/[0.06] flex items-center justify-center mx-auto mb-6">
              <svg class="w-6 h-6 text-[#2b3087]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                {ind.icon === 'shopping-cart' && <><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></>}
                {ind.icon === 'store' && <><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></>}
                {ind.icon === 'scissors' && <><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/></>}
                {ind.icon === 'truck' && <><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></>}
                {ind.icon === 'building' && <><rect x="4" y="2" width="16" height="20" rx="2" ry="2"/><path d="M9 22v-4h6v4"/><line x1="8" y1="6" x2="8" y2="6"/><line x1="12" y1="6" x2="12" y2="6"/><line x1="16" y1="6" x2="16" y2="6"/><line x1="8" y1="10" x2="8" y2="10"/><line x1="12" y1="10" x2="12" y2="10"/><line x1="16" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="8" y2="14"/><line x1="12" y1="14" x2="12" y2="14"/><line x1="16" y1="14" x2="16" y2="14"/></>}
                {ind.icon === 'utensils' && <><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 002-2V2"/><path d="M7 2v20"/><path d="M21 15V2v0a5 5 0 00-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/></>}
              </svg>
            </div>
            <h3 class="text-[16px] font-bold text-[#1a1a1a] mb-2 group-hover:text-[#2b3087] transition-colors">{ind.title}</h3>
            <p class="text-[13px] text-[#1a1a1a]/40 leading-relaxed">{ind.description}</p>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
  const scroll = document.querySelector('.industry-scroll') as HTMLElement;
  const prev = document.querySelector('.industry-prev') as HTMLElement;
  const next = document.querySelector('.industry-next') as HTMLElement;

  if (scroll && prev && next) {
    const step = 300;
    prev.addEventListener('click', () => {
      scroll.scrollBy({ left: -step, behavior: 'smooth' });
    });
    next.addEventListener('click', () => {
      scroll.scrollBy({ left: step, behavior: 'smooth' });
    });
  }
</script>
