---
import { services } from '../../data/services';
import { t } from '../../i18n/config';
---

<section id="services" class="pt-10 pb-24 md:pb-32 bg-white">
  <div class="max-w-[1656px] mx-auto px-6 lg:px-8">
    <div class="text-center mb-16 md:mb-20">
      <!-- Pill badge -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-black/[0.08] bg-white/60 backdrop-blur-sm mb-8">
        <svg class="w-4 h-4 text-[#1a1a1a]/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
        <span class="text-[16px] font-medium tracking-[0.2em] uppercase text-[#8a7a6b]">{t('services.eyebrow')}</span>
      </div>

      <!-- Title with gradient fade -->
      <h2 class="text-4xl md:text-5xl lg:text-[70px] font-extrabold leading-[1.1] tracking-tight mb-6">
        <span class="text-[#1a1a1a]">{t('services.title')}</span>
      </h2>

      <!-- Description -->
      <p class="max-w-2xl mx-auto text-[#1a1a1a]/40 text-[16px] leading-relaxed font-medium">{t('services.description')}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {services.map((service) => (
        <a href={`/ru/uslugi/${service.slug}/`} class="service-card group flex flex-col justify-between p-8 rounded-2xl border border-black/[0.06] bg-[#f8f8f8] hover:shadow-[0_8px_30px_rgba(0,0,0,0.08)] hover:border-black/[0.1] transition-all duration-300 relative overflow-hidden aspect-[4/3.5]">
          <canvas class="card-dots absolute inset-0 w-full h-full pointer-events-none"></canvas>
          <div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-black/[0.04] to-transparent"></div>

          <div class="relative z-10 flex justify-end">
            {service.tag ? (
              <span class="text-[11px] font-semibold text-[#2b3087] bg-[#2b3087]/[0.07] px-2.5 py-1 rounded-full">{service.tag}</span>
            ) : <span></span>}
          </div>

          <div class="relative z-10 text-center">
            <h3 class="text-[30px] font-extrabold text-[#1a1a1a] mb-3 group-hover:text-[#2b3087] transition-colors">{service.title}</h3>
            <p class="text-[14px] text-[#1a1a1a]/40 leading-relaxed">{service.description}</p>
          </div>

          <div class="relative z-10 flex items-center justify-between">
            <div class="w-10 h-10 rounded-full bg-[#1a1a1a]/[0.06] flex items-center justify-center">
              <svg class="w-5 h-5 text-[#1a1a1a]/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                {service.icon === 'message-circle' && <><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></>}
                {service.icon === 'database' && <><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></>}
                {service.icon === 'globe' && <><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></>}
                {service.icon === 'truck' && <><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></>}
                {service.icon === 'calendar' && <><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></>}
                {service.icon === 'package' && <><line x1="16.5" y1="9.4" x2="7.5" y2="4.21"/><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></>}
              </svg>
            </div>
            <span class="inline-flex items-center gap-1.5 text-[#1a1a1a]/40 text-[14px] font-medium group-hover:text-[#1a1a1a]/70 group-hover:gap-2.5 transition-all">
              {t('services.link')}
              <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="4" y1="12" x2="12" y2="4"/><polyline points="5,4 12,4 12,11"/></svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<script>
  const CELL = 130;
  const INFLUENCE = 150;
  const COLOR = { r: 43, g: 48, b: 135 };

  document.querySelectorAll('.service-card').forEach((card) => {
    const canvas = card.querySelector('.card-dots') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d')!;
    let mouse = { x: -1000, y: -1000 };

    function setup() {
      const dpr = window.devicePixelRatio || 1;
      const w = (card as HTMLElement).clientWidth;
      const h = (card as HTMLElement).clientHeight;
      canvas.width = w * dpr;
      canvas.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    function draw() {
      const w = (card as HTMLElement).clientWidth;
      const h = (card as HTMLElement).clientHeight;
      ctx.clearRect(0, 0, w, h);

      // 4 vertical lines, 4 horizontal lines — evenly spaced inside card
      const vLines = 4;
      const hLines = 4;
      const STEPS = 50; // points per line for smooth deformation

      ctx.strokeStyle = 'rgba(0,0,0,0.08)';
      ctx.lineWidth = 0.5;

      // Draw horizontal lines
      for (let i = 0; i < hLines; i++) {
        const baseY = (h / (hLines + 1)) * (i + 1);
        ctx.beginPath();
        for (let s = 0; s <= STEPS; s++) {
          let x = (w / STEPS) * s;
          let y = baseY;
          const dx = x - mouse.x;
          const dy = y - mouse.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < INFLUENCE && dist > 0) {
            const force = (INFLUENCE - dist) / INFLUENCE;
            x += (dx / dist) * force * 20;
            y += (dy / dist) * force * 20;
          }
          if (s === 0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        }
        ctx.stroke();
      }

      // Draw vertical lines
      for (let i = 0; i < vLines; i++) {
        const baseX = (w / (vLines + 1)) * (i + 1);
        ctx.beginPath();
        for (let s = 0; s <= STEPS; s++) {
          let x = baseX;
          let y = (h / STEPS) * s;
          const dx = x - mouse.x;
          const dy = y - mouse.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < INFLUENCE && dist > 0) {
            const force = (INFLUENCE - dist) / INFLUENCE;
            x += (dx / dist) * force * 20;
            y += (dy / dist) * force * 20;
          }
          if (s === 0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        }
        ctx.stroke();
      }

      // Dots at intersections near mouse
      for (let i = 0; i < hLines; i++) {
        for (let j = 0; j < vLines; j++) {
          let x = (w / (vLines + 1)) * (j + 1);
          let y = (h / (hLines + 1)) * (i + 1);
          const dx = x - mouse.x;
          const dy = y - mouse.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < INFLUENCE && dist > 0) {
            const force = (INFLUENCE - dist) / INFLUENCE;
            x += (dx / dist) * force * 20;
            y += (dy / dist) * force * 20;
          }
          const t = Math.max(0, 1 - dist / INFLUENCE);
          if (t > 0.05) {
            ctx.beginPath();
            ctx.arc(x, y, 1 + t * 2.5, 0, Math.PI * 2);
            ctx.fillStyle = `rgba(${COLOR.r},${COLOR.g},${COLOR.b},${t * 0.6})`;
            ctx.fill();
          }
        }
      }

      requestAnimationFrame(draw);
    }

    card.addEventListener('mousemove', (e: Event) => {
      const me = e as MouseEvent;
      const rect = (card as HTMLElement).getBoundingClientRect();
      mouse.x = me.clientX - rect.left;
      mouse.y = me.clientY - rect.top;
    });

    card.addEventListener('mouseleave', () => {
      mouse = { x: -1000, y: -1000 };
    });

    setup();
    draw();
    window.addEventListener('resize', setup);
  });
</script>
