---
import { services } from '../../data/services';
import { t } from '../../i18n/config';
---

<section id="services" class="py-24 md:py-32">
  <div class="max-w-[1120px] mx-auto px-6 lg:px-8">
    <div class="max-w-2xl mb-16">
      <p class="text-accent font-medium text-sm uppercase tracking-[0.2em] mb-4">{t('services.eyebrow')}</p>
      <h2 class="text-3xl md:text-4xl font-bold text-primary leading-tight">{t('services.title')}</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service) => (
        <a href={`/ru/uslugi/${service.slug}/`} class="group block p-6 rounded-xl border border-border bg-white hover:border-primary/30 hover:shadow-lg transition-all duration-300">
          <div class="flex items-start justify-between mb-4">
            <div class="w-12 h-12 rounded-xl bg-primary/5 flex items-center justify-center text-primary text-xl">
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                {service.icon === 'message-circle' && <><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></>}
                {service.icon === 'database' && <><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></>}
                {service.icon === 'globe' && <><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></>}
                {service.icon === 'truck' && <><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></>}
                {service.icon === 'calendar' && <><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></>}
                {service.icon === 'package' && <><line x1="16.5" y1="9.4" x2="7.5" y2="4.21"/><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></>}
              </svg>
            </div>
            {service.tag && (
              <span class="text-xs font-semibold text-accent bg-accent/10 px-2.5 py-1 rounded-full">{service.tag}</span>
            )}
          </div>

          <h3 class="text-lg font-bold text-primary mb-2 group-hover:text-primary-light transition-colors">{service.title}</h3>
          <p class="text-sm text-gray leading-relaxed mb-4">{service.description}</p>

          <span class="inline-flex items-center gap-1.5 text-primary text-sm font-medium group-hover:gap-2.5 transition-all">
            {t('services.link')}
            <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="8" x2="13" y2="8"/><polyline points="9,4 13,8 9,12"/></svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
