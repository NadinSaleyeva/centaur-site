---
import { mainNav, ctaNav } from '../../data/navigation';
---

<header class="fixed top-0 left-0 right-0 z-50 px-4 pt-4" id="main-header">
  <nav class="max-w-[1656px] mx-auto bg-white/70 backdrop-blur-xl rounded-full px-8 lg:px-10 border border-black/[0.06] shadow-[0_2px_20px_rgba(0,0,0,0.06)]">
    <div class="flex items-center justify-between h-[90px]">
      <!-- Logo -->
      <a href="/ru/" class="block shrink-0 -translate-y-1">
        <img src="/images/logo.svg" alt="Centaur Labs" class="h-12 w-auto" id="header-logo-img" />
      </a>

      <!-- Desktop nav (center) -->
      <div class="hidden lg:flex items-center gap-7">
        {mainNav.map((item) => (
          <div class="relative group">
            <a
              href={item.href}
              class="header-link text-[#1a1a1a]/60 hover:text-[#1a1a1a] text-[16px] font-medium transition-colors duration-200 flex items-center gap-1"
            >
              {item.label}
              {item.children && (
                <svg class="w-3 h-3 opacity-40" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 5l3 3 3-3"/></svg>
              )}
            </a>

            {item.children && (
              <div class="absolute top-full left-1/2 -translate-x-1/2 pt-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
                <div class="bg-white/90 backdrop-blur-xl rounded-2xl shadow-lg border border-black/[0.06] py-2 min-w-[220px]">
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class="block px-4 py-2.5 text-sm text-[#1a1a1a]/70 hover:text-[#1a1a1a] hover:bg-black/[0.03] transition-colors"
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
      </div>

      <!-- Right side: socials + CTA -->
      <div class="hidden lg:flex items-center gap-5">
        <div class="flex items-center gap-5">
          <a href="https://t.me/centaurlabs" target="_blank" rel="noopener noreferrer" class="text-[#1a1a1a]/25 hover:text-[#1a1a1a]/60 transition-colors" aria-label="Telegram">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
          </a>
          <a href="https://instagram.com/centaurlabs" target="_blank" rel="noopener noreferrer" class="text-[#1a1a1a]/25 hover:text-[#1a1a1a]/60 transition-colors" aria-label="Instagram">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
          </a>
          <a href="https://linkedin.com/company/centaurlabs" target="_blank" rel="noopener noreferrer" class="text-[#1a1a1a]/25 hover:text-[#1a1a1a]/60 transition-colors" aria-label="LinkedIn">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>

        <!-- CTA -->
        <a
          href={ctaNav.href}
          class="inline-flex items-center gap-2 px-6 py-2.5 rounded-full border border-[#1a1a1a]/20 text-[#1a1a1a] text-[16px] font-medium hover:bg-[#1a1a1a] hover:text-white transition-all duration-200"
        >
          {ctaNav.label}
          <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="4" y1="12" x2="12" y2="4"/><polyline points="5,4 12,4 12,11"/></svg>
        </a>
      </div>

      <!-- Mobile burger -->
      <button class="lg:hidden p-2 text-[#1a1a1a] header-burger" aria-label="Меню">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </nav>
</header>

<script>
  // No scroll state needed — pill header stays the same
</script>
