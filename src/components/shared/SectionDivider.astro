---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<div class="w-full pt-16 pb-8 bg-white">
  <div class="max-w-[1656px] mx-auto px-6 lg:px-8">
    <div class="flex items-center gap-4 pb-8 border-b border-[#e5e5e5]">
      <span class="block w-[60px] h-px bg-[#b0b0b0]"></span>
      <span class="text-[11px] font-medium tracking-[0.2em] uppercase text-[#8a7a6b]">{text}</span>
    </div>
  </div>
</div>
