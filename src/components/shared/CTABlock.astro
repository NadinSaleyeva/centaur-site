---
import { t } from '../../i18n/config';
---

<section id="cta" class="py-24 md:py-32 bg-accent-lightest">
  <div class="max-w-3xl mx-auto px-6 lg:px-8 text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-primary leading-tight mb-6">{t('cta.title')}</h2>
    <p class="text-lg text-gray leading-relaxed mb-10 max-w-2xl mx-auto">{t('cta.subtitle')}</p>

    <a
      href="/ru/audit/"
      class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-lg bg-primary text-white text-sm font-semibold uppercase tracking-wider hover:bg-primary-light transition-all duration-200"
    >
      {t('cta.primary')}
      <svg class="w-5 h-5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="4" y1="10" x2="16" y2="10"/><polyline points="11,5 16,10 11,15"/></svg>
    </a>

    <p class="text-sm text-gray mt-6">{t('cta.trust')}</p>
  </div>
</section>
