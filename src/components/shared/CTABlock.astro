---
import { t } from '../../i18n/config';
---

<section id="cta" class="py-32 md:py-40 bg-[#0a0a0f]">
  <div class="max-w-[1656px] mx-auto px-6 lg:px-8 text-center">
    <h2 class="text-4xl md:text-5xl lg:text-[70px] font-extrabold text-white leading-[1.1] tracking-tight mb-6">{t('cta.title')}</h2>
    <p class="max-w-2xl mx-auto text-white/40 text-[16px] leading-relaxed font-medium mb-12">{t('cta.subtitle')}</p>

    <a
      href="/ru/audit/"
      class="inline-flex items-center justify-center gap-3 px-8 py-4 rounded-full border border-white/20 text-white text-sm font-semibold uppercase tracking-wider hover:bg-white hover:text-[#0a0a0f] transition-all duration-300"
    >
      {t('cta.primary')}
      <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="4" y1="12" x2="12" y2="4"/><polyline points="5,4 12,4 12,11"/></svg>
    </a>

    <p class="text-sm text-white/30 mt-8">{t('cta.trust')}</p>
  </div>
</section>
